<?xml version="1.0"?>
<!-- Kinematic + inertial tree aligned with feixi URDF / MuJoCo feixi_with_gripper (no ros2_control).
     Used only by Pinocchio inverse dynamics (hardware plugin). -->
<robot name="feixi_pinocchio">
  <link name="world"/>

  <link name="base_link">
    <inertial>
      <origin xyz="-0.00021106538 -0.00012110009 0.093234927" rpy="0 0 0"/>
      <mass value="7.4102692"/>
      <inertia ixx="0.041009804" ixy="5.2228925e-05" ixz="1.73482e-05"
               iyy="0.040916598" iyz="-1.9102494e-05" izz="0.031217284"/>
    </inertial>
  </link>

  <link name="link1">
    <inertial>
      <origin xyz="-0.00029095491 -0.0035858819 0.15418313" rpy="0 0 0"/>
      <mass value="9.0144205"/>
      <inertia ixx="0.082550202" ixy="7.4319029e-05" ixz="7.0665272e-06"
               iyy="0.081963619" iyz="0.0018310621" izz="0.030529475"/>
    </inertial>
  </link>

  <link name="link2">
    <inertial>
      <origin xyz="-6.4713234e-05 0.063525121 0.067577715" rpy="0 0 0"/>
      <mass value="6.7570036"/>
      <inertia ixx="0.051911627" ixy="5.7490856e-06" ixz="-9.4102031e-06"
               iyy="0.053134761" iyz="0.00041544898" izz="0.018626617"/>
    </inertial>
  </link>

  <link name="link3">
    <inertial>
      <origin xyz="0.0003960789 -0.00041808556 0.13941829" rpy="0 0 0"/>
      <mass value="5.0247388"/>
      <inertia ixx="0.035483875" ixy="5.8174996e-06" ixz="3.7116793e-05"
               iyy="0.035211857" iyz="1.557697e-05" izz="0.010620295"/>
    </inertial>
  </link>

  <link name="link4">
    <inertial>
      <origin xyz="0.00011494995 0.056755076 0.063683236" rpy="0 0 0"/>
      <mass value="3.9685494"/>
      <inertia ixx="0.023090356" ixy="-8.5200568e-06" ixz="-2.178671e-05"
               iyy="0.022898562" iyz="-5.2887506e-05" izz="0.0073930755"/>
    </inertial>
  </link>

  <link name="link5">
    <inertial>
      <origin xyz="-0.00014372049 -0.0093849119 0.11679232" rpy="0 0 0"/>
      <mass value="2.7536846"/>
      <inertia ixx="0.013718484" ixy="-1.4297428e-05" ixz="6.9588203e-06"
               iyy="0.013540662" iyz="0.00097555493" izz="0.0038340901"/>
    </inertial>
  </link>

  <link name="link6">
    <inertial>
      <origin xyz="0.024266168 0.059349347 0.059586978" rpy="0 0 0"/>
      <mass value="2.9139461"/>
      <inertia ixx="0.010471625" ixy="-0.00059897658" ixz="-0.0022613776"
               iyy="0.011731545" iyz="-0.0015611765" izz="0.0062550184"/>
    </inertial>
  </link>

  <link name="link7">
    <inertial>
      <origin xyz="-3.0957835e-05 4.7993308e-06 0.038274347" rpy="0 0 0"/>
      <mass value="0.80570764"/>
      <inertia ixx="0.00087189474" ixy="-1.9998805e-06" ixz="1.1000774e-06"
               iyy="0.00087088066" iyz="6.172395e-07" izz="0.00093037058"/>
    </inertial>
  </link>

  <!-- Logical 1-DoF gripper (matches ros2_control joint name). -->
  <link name="gripper_logical_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.21" rpy="0 0 -3.141592653589793"/>
    <axis xyz="0 0 1"/>
    <limit effort="261" velocity="3.14" lower="-2.8798" upper="2.8798"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0.0675 0.24" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="261" velocity="3.14" lower="-2.7576" upper="2.7576"/>
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0.0625 0.2275" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="123" velocity="3.14" lower="-2.8798" upper="2.8798"/>
  </joint>

  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 -0.0625 0.2225" rpy="0 0 -3.141592653589793"/>
    <axis xyz="0 1 0"/>
    <limit effort="123" velocity="3.14" lower="-2.7925" upper="2.7925"/>
  </joint>

  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0.0575 0.205" rpy="0 0 -3.141592653589793"/>
    <axis xyz="0 0 1"/>
    <limit effort="57" velocity="3.14" lower="-3.0543" upper="3.0543"/>
  </joint>

  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0.03 0.19" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="57" velocity="3.14" lower="-1.4835" upper="4.6251"/>
  </joint>

  <joint name="joint7" type="revolute">
    <parent link="link6"/>
    <child link="link7"/>
    <origin xyz="-0.015 0.073 0.11" rpy="0 -1.5707963478683205 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="57" velocity="3.14" lower="-3.0543" upper="3.0543"/>
  </joint>

  <joint name="gripper_finger_joint" type="revolute">
    <parent link="link7"/>
    <child link="gripper_logical_link"/>
    <origin xyz="0 0 0.077" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="50" velocity="2.0" lower="0" upper="0.85"/>
  </joint>
</robot>
