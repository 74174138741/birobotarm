<mujoco model="feixi_with_gripper">
  <compiler angle="radian" autolimits="true" meshdir="." texturedir="."/>
  <option timestep="0.002" integrator="implicitfast" gravity="0 0 -9.81"/>

  <default>
    <joint type="hinge" damping="0.5" armature="0.01"/>
    <motor ctrllimited="true"/>

    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.75 0.75 0.75 1"/>
    </default>
    <default class="collision">
      <geom type="mesh" contype="1" conaffinity="1" group="3" rgba="0 0 0 0"/>
    </default>

    <default class="xarm7_hand">
      <geom type="mesh" material="hand_black"/>
      <joint range="0 0.85" axis="1 0 0" armature="0.1" frictionloss="1"/>
      <site size="0.001" rgba="1 0 0 1" group="4"/>
      <general biastype="affine" forcerange="-50 50" ctrlrange="0 255" gainprm="0.333" biasprm="0 -100 -10"/>
      <default class="spring_link">
        <joint stiffness="0.05" springref="2.62" damping="0.00125"/>
      </default>
      <default class="driver">
        <joint armature="0.005" damping="0.1" solreflimit="0.005 1"/>
      </default>
      <default class="follower">
        <joint solreflimit="0.005 1"/>
      </default>
      <default class="hand_visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="hand_collision">
        <geom type="mesh" group="3"/>
        <default class="pad_box1">
          <geom type="box" friction="0.7" solimp="0.95 0.99 0.001" solref="0.004 1" mass="0" priority="1" size="0.015 0.002 0.0095" rgba="0.0 0.1 0.7 1"/>
        </default>
        <default class="pad_box2">
          <geom type="box" friction="0.6" solimp="0.95 0.99 0.001" solref="0.004 1" mass="0" priority="1" size="0.015 0.002 0.0095" rgba="0.0 0.5 0.5 1"/>
        </default>
      </default>
    </default>
  </default>

  <asset>
    <material name="hand_white" rgba="1 1 1 1"/>
    <material name="hand_black" rgba="0.149 0.149 0.149 1"/>

    <mesh name="link0_v" file="visual/link0.obj"/>
    <mesh name="link1_v" file="visual/link1.obj"/>
    <mesh name="link2_v" file="visual/link2.obj"/>
    <mesh name="link3_v" file="visual/link3.obj"/>
    <mesh name="link4_v" file="visual/link4.obj"/>
    <mesh name="link5_v" file="visual/link5.obj"/>
    <mesh name="link6_v" file="visual/link6.obj"/>
    <mesh name="link7_v" file="visual/link7.obj"/>
    <mesh name="link0_c" file="collision/link0.stl"/>
    <mesh name="link1_c" file="collision/link1.stl"/>
    <mesh name="link2_c" file="collision/link2.stl"/>
    <mesh name="link3_c" file="collision/link3.stl"/>
    <mesh name="link4_c" file="collision/link4.stl"/>
    <mesh name="link5_c" file="collision/link5.stl"/>
    <mesh name="link6_c" file="collision/link6.stl"/>
    <mesh name="link7_c" file="collision/link7.stl"/>

    <mesh name="hg_base_link" file="../hand/visual/base_link.stl"/>
    <mesh name="hg_left_outer_knuckle" file="../hand/visual/left_outer_knuckle.stl"/>
    <mesh name="hg_left_finger" file="../hand/visual/left_finger.stl"/>
    <mesh name="hg_left_inner_knuckle" file="../hand/visual/left_inner_knuckle.stl"/>
    <mesh name="hg_right_outer_knuckle" file="../hand/visual/right_outer_knuckle.stl"/>
    <mesh name="hg_right_finger" file="../hand/visual/right_finger.stl"/>
    <mesh name="hg_right_inner_knuckle" file="../hand/visual/right_inner_knuckle.stl"/>
  </asset>

  <worldbody>
    <body name="base_link">
      <geom class="visual" mesh="link0_v"/>
      <geom class="collision" mesh="link0_c"/>

      <body name="link1" pos="0 0 0.21" euler="0 0 -3.141592653589793">
        <joint name="joint1" axis="0 0 1" range="-2.8798 2.8798"/>
        <geom class="visual" mesh="link1_v"/>
        <geom class="collision" mesh="link1_c"/>

        <body name="link2" pos="0 0.0675 0.24">
          <joint name="joint2" axis="0 1 0" range="-2.7576 2.7576"/>
          <geom class="visual" mesh="link2_v"/>
          <geom class="collision" mesh="link2_c"/>

          <body name="link3" pos="0 0.0625 0.2275">
            <joint name="joint3" axis="0 0 1" range="-2.8798 2.8798"/>
            <geom class="visual" mesh="link3_v"/>
            <geom class="collision" mesh="link3_c"/>

            <body name="link4" pos="0 -0.0625 0.2225" euler="0 0 -3.141592653589793">
              <joint name="joint4" axis="0 1 0" range="-2.7925 2.7925"/>
              <geom class="visual" mesh="link4_v"/>
              <geom class="collision" mesh="link4_c"/>

              <body name="link5" pos="0 0.0575 0.205" euler="0 0 -3.141592653589793">
                <joint name="joint5" axis="0 0 1" range="-3.0543 3.0543"/>
                <geom class="visual" mesh="link5_v"/>
                <geom class="collision" mesh="link5_c"/>

                <body name="link6" pos="0 0.03 0.19">
                  <joint name="joint6" axis="0 1 0" range="-1.4835 4.6251"/>
                  <geom class="visual" mesh="link6_v"/>
                  <geom class="collision" mesh="link6_c"/>

                  <body name="link7" pos="-0.015 0.073 0.11" euler="0 -1.5707963478683205 0">
                    <joint name="joint7" axis="0 0 1" range="-3.0543 3.0543"/>
                    <geom class="visual" mesh="link7_c"/>
                    <geom class="collision" mesh="link7_c"/>

                    <!-- Gripper mount: link7 visual mesh spans ~z in [0, 0.081] m in this frame; offset to flange end (was 0,0,0 at joint → inside link). -->
                    <body name="xarm_gripper_base_link" pos="0 0 0.077" childclass="xarm7_hand">
                      <inertial pos="-0.00065489 -0.0018497 0.048028" quat="0.997403 -0.0717512 -0.0061836 0.000477479" mass="0.54156"
                        diaginertia="0.000471093 0.000332307 0.000254799"/>
                      <geom mesh="hg_base_link" material="hand_white"/>
                      <body name="left_outer_knuckle" pos="0 0.035 0.059098">
                        <inertial pos="0 0.021559 0.015181" quat="0.47789 0.87842 0 0" mass="0.033618"
                          diaginertia="1.9111e-05 1.79089e-05 1.90167e-06"/>
                        <joint name="left_driver_joint" class="driver"/>
                        <geom material="hand_black" mesh="hg_left_outer_knuckle"/>
                        <body name="left_finger" pos="0 0.035465 0.042039">
                          <inertial pos="0 -0.016413 0.029258" quat="0.697634 0.115353 -0.115353 0.697634" mass="0.048304"
                            diaginertia="1.88037e-05 1.7493e-05 3.56792e-06"/>
                          <joint name="left_finger_joint" axis="-1 0 0" class="follower"/>
                          <geom class="hand_visual" material="hand_black" mesh="hg_left_finger"/>
                          <geom class="pad_box1" name="left_finger_pad_1" pos="0 -0.024003 0.032"/>
                          <geom class="pad_box2" name="left_finger_pad_2" pos="0 -0.024003 0.050"/>
                        </body>
                      </body>
                      <body name="left_inner_knuckle" pos="0 0.02 0.074098">
                        <inertial pos="1.86601e-06 0.0220468 0.0261335" quat="0.664139 -0.242732 0.242713 0.664146" mass="0.0230126"
                          diaginertia="8.34216e-06 6.0949e-06 2.75601e-06"/>
                        <joint name="left_inner_knuckle_joint" class="spring_link"/>
                        <geom material="hand_black" mesh="hg_left_inner_knuckle"/>
                      </body>
                      <body name="right_outer_knuckle" pos="0 -0.035 0.059098">
                        <inertial pos="0 -0.021559 0.015181" quat="0.87842 0.47789 0 0" mass="0.033618"
                          diaginertia="1.9111e-05 1.79089e-05 1.90167e-06"/>
                        <joint name="right_driver_joint" axis="-1 0 0" class="driver"/>
                        <geom material="hand_black" mesh="hg_right_outer_knuckle"/>
                        <body name="right_finger" pos="0 -0.035465 0.042039">
                          <inertial pos="0 0.016413 0.029258" quat="0.697634 -0.115356 0.115356 0.697634" mass="0.048304"
                            diaginertia="1.88038e-05 1.7493e-05 3.56779e-06"/>
                          <joint name="right_finger_joint" class="follower"/>
                          <geom class="hand_visual" material="hand_black" mesh="hg_right_finger"/>
                          <geom class="pad_box1" name="right_finger_pad_1" pos="0 0.024003 0.032"/>
                          <geom class="pad_box2" name="right_finger_pad_2" pos="0 0.024003 0.050"/>
                        </body>
                      </body>
                      <body name="right_inner_knuckle" pos="0 -0.02 0.074098">
                        <inertial pos="1.866e-06 -0.022047 0.026133" quat="0.66415 0.242702 -0.242721 0.664144" mass="0.023013"
                          diaginertia="8.34209e-06 6.0949e-06 2.75601e-06"/>
                        <joint name="right_inner_knuckle_joint" axis="-1 0 0" class="spring_link"/>
                        <geom material="hand_black" mesh="hg_right_inner_knuckle"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="right_inner_knuckle" body2="right_outer_knuckle"/>
    <exclude body1="right_inner_knuckle" body2="right_finger"/>
    <exclude body1="left_inner_knuckle" body2="left_outer_knuckle"/>
    <exclude body1="left_inner_knuckle" body2="left_finger"/>
    <exclude body1="left_inner_knuckle" body2="xarm_gripper_base_link"/>
    <exclude body1="right_inner_knuckle" body2="xarm_gripper_base_link"/>
    <exclude body1="left_outer_knuckle" body2="xarm_gripper_base_link"/>
    <exclude body1="right_outer_knuckle" body2="xarm_gripper_base_link"/>
  </contact>

  <tendon>
    <fixed name="split">
      <joint joint="right_driver_joint" coef="0.5"/>
      <joint joint="left_driver_joint" coef="0.5"/>
    </fixed>
  </tendon>

  <equality>
    <connect anchor="0 0.015 0.015" body1="right_finger" body2="right_inner_knuckle" solref="0.005 1"/>
    <connect anchor="0 -0.015 0.015" body1="left_finger" body2="left_inner_knuckle" solref="0.005 1"/>
    <joint joint1="left_driver_joint" joint2="right_driver_joint" polycoef="0 1 0 0 0" solref="0.005 1"/>
  </equality>

  <actuator>
    <motor name="m_joint1" joint="joint1" ctrlrange="-261 261" gear="1"/>
    <motor name="m_joint2" joint="joint2" ctrlrange="-261 261" gear="1"/>
    <motor name="m_joint3" joint="joint3" ctrlrange="-123 123" gear="1"/>
    <motor name="m_joint4" joint="joint4" ctrlrange="-123 123" gear="1"/>
    <motor name="m_joint5" joint="joint5" ctrlrange="-57 57" gear="1"/>
    <motor name="m_joint6" joint="joint6" ctrlrange="-57 57" gear="1"/>
    <motor name="m_joint7" joint="joint7" ctrlrange="-57 57" gear="1"/>
    <general class="xarm7_hand" name="fingers_actuator" tendon="split"/>
  </actuator>
</mujoco>
